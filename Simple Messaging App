def main():
    try:
        with open("message.txt", "x"):
            print("Success! message.txt file created successfully.")
    except FileExistsError:
        print("Error: message.txt file already exists.")
    except Exception as e:
        print(f"Error: {e}")

    while True:
        print("\n1. Send a message\n2. View all messages\n3. Exit")
        choice = input("Enter your choice (1-3): ").strip()
        if choice == "1":
            try:
                m = input("Enter your message: ").strip()
                if not m:
                    raise ValueError("Message cannot be empty.")
                with open("message.txt", "a") as f:
                    f.write(m + "\n")
                print("Message sent successfully!")
            except FileNotFoundError:
                print("Error: message.txt file not found.")
            except Exception as e:
                print("Error: {e}")
        elif choice == "2":
            try:
                with open("message.txt", "r") as f:
                    t = f.read().strip()
                if t:
                    print(f"\nAll Messages\n{t}\nEnd of Messages\n")
                else:
                    print("\nAll Messages\n{'No messages found in message.txt.'}\nEnd of Messages\n")
            except FileNotFoundError:
                print("Error: message.txt file not found.")
            except Exception as e:
                print("Error: {e}")
        elif choice == "3":
            print("Sayonara!")
            break
        else:
            print("Error: Invalid choice.")


if __name__ == "__main__":
    main()
